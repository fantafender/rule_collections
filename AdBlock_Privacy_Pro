  - domain_keyword:
      match: pingfore
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: supersonicads
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: uedas
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: umeng
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: usage
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: wlmonitor
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: zjtoolbar
      policy: REJECT-TINYGIF
  - domain_suffix:
      match: appsflyer.com
      policy: REJECT-TINYGIF
  - domain_suffix:
      match: doubleclick.net
      policy: REJECT-TINYGIF
  - domain_suffix:
      match: mmstat.com
      policy: REJECT-TINYGIF
  - domain_suffix:
      match: vungle.com
      policy: REJECT-TINYGIF

  # === B. 远程规则集拦截 (RULE-SET) ===
  - rule_set:
      match: https://ruleset.skk.moe/List/non_ip/reject-drop.conf
      policy: REJECT-DROP
  - rule_set:
      match: https://ruleset.skk.moe/List/ip/reject.conf
      policy: REJECT-DROP
  - rule_set:
      match: https://ruleset.skk.moe/List/non_ip/reject-no-drop.conf
      policy: REJECT-NO-DROP
  - rule_set:
      match: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Privacy/Privacy.list
      policy: REJECT
  - rule_set:
      match: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Surge/Hijacking/Hijacking.list
      policy: REJECT
  - rule_set:
      match: https://raw.githubusercontent.com/Centralmatrix3/Matrix-io/master/Egern/Ruleset/Advertising.yaml
      policy: REJECT

  # === C. 大规模域名集拦截 (DOMAIN-SET) ===
  - domain_set:
      match: https://ruleset.skk.moe/List/domainset/reject_extra.conf
      policy: REJECT
  - domain_set:
      match: https://ruleset.skk.moe/List/domainset/reject.conf
      policy: REJECT
