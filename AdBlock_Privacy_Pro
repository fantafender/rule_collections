  - domain_keyword:
      match: adwords
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: adservice
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: domob
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: duomeng
      policy: REJECT-TINYGIF
  - domain_keyword:
      match: dwtrack
      policy: REJECT-TINYGIF
  - domain_keyword:
