  // ===================== ChatGPT 检测（按 checkref2.MediaUnlockTest_ChatGPT 思路，输出仅 ❌ / APP / 地区码）=====================
  async function checkChatGPT(ctx) {
    try {
      // 1) 访问 chatgpt.com 取响应头（看是否有 Location，代表 Web 访问是否可用）
      const headRes = await ctx.http.get("https://chatgpt.com", {
        timeout: 10000,
        headers: { "User-Agent": BASE_UA },
        followRedirect: false
      }).catch(() => null);
      const headOk = !!headRes;
      const locationHeader = (headRes?.headers?.location || headRes?.headers?.Location || "");
      const webAccessible = headOk && !!locationHeader;

      // 2) 访问 ios.chat.openai.com 拿正文和 cf_details（代表 APP 接口是否可用）
      const iosRes = await ctx.http.get("https://ios.chat.openai.com", {
        timeout: 10000,
        headers: { "User-Agent": BASE_UA },
        followRedirect: true
      }).catch(() => null);
      const iosBody = await readBody(iosRes);

      // 解析 cf_details（可能在 JSON 或内嵌脚本）
      let cfDetails = "";
      try {
        const asJson = iosBody ? JSON.parse(iosBody) : null;
        if (asJson && asJson.cf_details) cfDetails = String(asJson.cf_details);
      } catch {
        const m = iosBody ? iosBody.match(/"cf_details"\s*:\s*"([^"]*)"/) : null;
        if (m?.[1]) cfDetails = m[1];
      }

      // 识别 APP 是否被屏蔽（常见的 blocked / unsupported 字样 或 cf_details 标记）
      const appBlocked = !iosBody
        || iosBody.includes("blocked_why_headline")
        || iosBody.includes("unsupported_country_region_territory")
        || cfDetails.includes("(1)")
        || cfDetails.includes("(2)");
      const appAccessible = !!iosBody && !appBlocked;

      // 3) 三类输出决定逻辑：
      // - 两者都不可用 => ❌
      if (!webAccessible && !appAccessible) return "❌";
      // - 仅 APP 可用 => APP
      if (appAccessible && !webAccessible) return "APP";
      // - 两者都可用 => 返回地区码（优先用 Cloudflare trace）
      if (webAccessible && appAccessible) {
        const traceRes = await ctx.http.get("https://chatgpt.com/cdn-cgi/trace", {
          timeout: 8000,
          headers: { "User-Agent": BASE_UA },
          followRedirect: true
        }).catch(() => null);
        const traceTxt = await readBody(traceRes);
        if (traceTxt) {
          const m = traceTxt.match(/loc=([A-Z]{2})/);
          if (m?.[1]) return m[1];
        }
        // Trace 失败时仍返回 XX 表示未知地区（界面按需显示 OK/XX）
        return "XX";
      }

      // 兜底
      return "❌";
    } catch {
      return "❌";
    }
  }


