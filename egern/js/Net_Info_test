export default async function(ctx) {
  const BG_CARD = { light: '#FFFFFF', dark: '#1C1E1E' };
  const C_TEXT  = { light: '#000000', dark: '#FFFFFF' };
  const C_SUB   = { light: '#6E6E73', dark: '#8E8E93' };
  const C_BLUE  = { light: '#007AFF', dark: '#0A84FF' };
  const C_GREEN = { light: '#34C759', dark: '#30D158' };
  const C_ORANGE= { light: '#FF9500', dark: '#FF9F0A' };
  const C_RED   = { light: '#FF3B30', dark: '#FF453A' };
  const C_YELLOW= { light: '#FFCC00', dark: '#FFD60A' };

  const DEFAULT_ISP = '未知运营商';

  // ===== ISP识别 =====
  function getISPByASN(asn) {
    const a = (asn || '').replace(/^AS/, '');
    return {
      '9231':'CMHK','9381':'CTHK','4609':'CTM',
      '15557':'SFR','12322':'Free','3215':'Orange','5410':'Bouygues'
    }[a] || null;
  }

  function getISPByIPIP(raw, loc) {
    const s = (raw || '').toLowerCase();
    const area = (loc[1] || '').toLowerCase();

    if (area.includes('香港')) {
      if (s.includes('mobile')) return 'CMHK';
      if (s.includes('telecom')) return 'CTHK';
      return '香港运营商';
    }

    if (area.includes('澳门')) return 'CTM';

    if (area.includes('法国') || area.includes('巴黎')) {
      if (s.includes('orange')) return 'Orange';
      if (s.includes('free')) return 'Free';
      if (s.includes('bouygues')) return 'Bouygues';
      if (s.includes('sfr')) return 'SFR';
      return '法国运营商';
    }

    if (/(移动|cmcc)/i.test(s)) return '中国移动';
    if (/(电信)/i.test(s)) return '中国电信';
    if (/(联通)/i.test(s)) return '中国联通';

    return DEFAULT_ISP;
  }

  function getFlag(code) {
    return code
      ? String.fromCodePoint(...code.toUpperCase().split('').map(c => 127397 + c.charCodeAt()))
      : "🌐";
  }

  // ===== 网络信息 =====
  const d = ctx.device || {};
  const isWifi = !!d.wifi?.ssid;

  let netName = "未连接", netIcon = "antenna.radiowaves.left.and.right";

  if (isWifi) {
    netName = d.wifi.ssid || "Wi-Fi";
    netIcon = "wifi";
  } else if (d.cellular?.radio) {
    const map = {
      GPRS:"2.5G", EDGE:"2.75G", WCDMA:"3G",
      LTE:"4G", NR:"5G", NRNSA:"5G"
    };
    const r = d.cellular.radio.toUpperCase();
    netName = `蜂窝 ${map[r] || r}`;
  }

  const localIp = d.ipv4?.address || "—";

  // ===== 🚀 并发请求 =====
  const [ipipR, ipinfoR, ippureR] = await Promise.allSettled([
    ctx.http.get('https://myip.ipip.net/json', { timeout: 3000 }),
    ctx.http.get('https://ipinfo.io/json', { timeout: 3000 }),
    ctx.http.get('https://my.ippure.com/v1/info', { timeout: 3000 })
  ]);

  // ===== 直连IP =====
  let pubIp="—", pubLoc="—", pubIsp=DEFAULT_ISP;

  if (ipipR.status === 'fulfilled') {
    try {
      const body = await ipipR.value.json();
      pubIp = body?.data?.ip || "—";

      const loc = body?.data?.location || [];
      const rawIsp = loc[4] || loc[3] || '';

      pubIsp = getISPByIPIP(rawIsp, loc);

      const country = loc[0] === '中国' ? 'CN' :
                      loc[1]?.includes('香港') ? 'HK' :
                      loc[1]?.includes('法国') ? 'FR' : '';

      pubLoc = `${getFlag(country)} ${loc[1] || ""} ${loc[2] || ""}`.trim();

    } catch {}
  }

  // ===== 落地IP =====
  let nIp="—", nLoc="—", asnInfo="—";

  if (ipinfoR.status === 'fulfilled') {
    try {
      const dt = await ipinfoR.value.json();
      nIp = dt.ip || "—";
      nLoc = `${getFlag(dt.country)} ${dt.region || ""} ${dt.city || ""}`;
      asnInfo = dt.org || "—";
    } catch {}
  }

  // ===== 风险 =====
  let riskTxt="…", riskCol=C_SUB, riskIcon="clock", delayText="…";

  if (ippureR.status === 'fulfilled') {
    try {
      const start = Date.now();
      const data = await ippureR.value.json();
      const cost = Date.now() - start;

      delayText = `${cost}ms`;

      const r = data.fraudScore;
      if (r >= 80) { riskTxt=`高危 ${r}`; riskCol=C_RED; riskIcon="xmark.shield.fill"; }
      else if (r >= 50) { riskTxt=`中风险 ${r}`; riskCol=C_ORANGE; }
      else { riskTxt=`纯净 ${r}`; riskCol=C_GREEN; }

      if (data.isResidential === true) nIp += " 🏠";
      else if (data.isResidential === false) nIp += " 🏢";

    } catch {}
  }

  // ===== UI 行（对齐优化）=====
  const Row = (ic, icCol, label, val, valCol) => ({
    type:'stack',
    direction:'row',
    alignItems:'center',
    padding:[1,0],
    children:[
      { type:'image', src:`sf-symbol:${ic}`, color:icCol, width:11, height:11 },
      { type:'spacer', length:4 },
      { type:'text', text:label, font:{ size:10 }, textColor:C_SUB, frame:{ width:52 }},
      { type:'spacer' },
      { type:'text', text:val, font:{ size:11, weight:'medium' }, textColor:valCol, maxLines:1 }
    ]
  });

  return {
    type:'widget',
    padding:[8,10],
    backgroundColor:BG_CARD,
    cornerRadius:12,
    refreshPolicy:{ onNetworkChange:true, onEnter:true },

    children:[
      {
        type:'stack',
        direction:'row',
        alignItems:'center',
        padding:[0,0,4,0],
        children:[
          { type:'image', src:`sf-symbol:${netIcon}`, color:C_BLUE, width:16, height:16 },
          { type:'spacer', length:6 },
          { type:'text', text:netName, font:{ size:14, weight:'bold' }, textColor:C_TEXT },
          { type:'spacer' },
          { type:'text', text:delayText, font:{ size:12 }, textColor:C_SUB }
        ]
      },

      Row("iphone", C_GREEN, "内网IP", localIp, C_TEXT),
      Row("globe", C_BLUE, "直连IP", `${pubIp} (${pubIsp})`, C_TEXT),
      Row("mappin", C_SUB, "位置", pubLoc, C_TEXT),
      Row("paperplane.fill", C_BLUE, "落地IP", nIp, C_TEXT),
      Row("number.square.fill", C_SUB, "ASN", asnInfo, C_TEXT),
      Row(riskIcon, riskCol, "风险", riskTxt, riskCol),
    ]
  };
}
