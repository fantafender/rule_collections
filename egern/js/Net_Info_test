export default async function(ctx) {
  // ===================== 样式常量（light/dark 双模式）=====================
  const BG_CARD = { light: '#FFFFFF', dark: '#1C1E1E' };
  const C_TEXT  = { light: '#000000', dark: '#FFFFFF' };
  const C_SUB   = { light: '#6E6E73', dark: '#8E8E93' };
  const C_BLUE  = { light: '#007AFF', dark: '#0A84FF' };
  const C_GREEN = { light: '#34C759', dark: '#30D158' };
  const C_YELLOW= { light: '#FF9F0A', dark: '#FF9F0A' };
  const C_RED   = { light: '#FF3B30', dark: '#FF453A' };

  // ===================== 辅助函数：获取系统主题适配的颜色 =====================
  const getThemeColor = (colorObj) => {
    const isDarkMode = ctx?.device?.colorScheme === 'dark' || false;
    return isDarkMode ? colorObj.dark : colorObj.light;
  };

  // ===================== IP类型判断 =====================
  function getIPType(isp, org) {
    const raw = `${isp} ${org}`.toLowerCase();
    if (raw.includes('residential') || raw.includes('consumer') || raw.includes('home') || 
        raw.includes('住户') || raw.includes('家庭')) {
      return "🏠 住宅";
    }
    if (raw.includes('datacenter') || raw.includes('hosting') || raw.includes('server') || 
        raw.includes('机房') || raw.includes('数据中心')) {
      return "🏢 机房";
    }
    if (raw.includes('mobile') || raw.includes('cellular') || raw.includes('移动') || raw.includes('蜂窝')) {
      return "📶 移动";
    }
    return "🌐 固定IP";
  }

  // ===================== 运营商识别 =====================
  function getISPByASN(asn) {
    const asnCode = (asn || "").trim().replace(/^AS/, "");
    switch (asnCode) {
      case "9231": return "CMHK";
      case "9381": return "CTHK";
      case "4609": return "CTM";
      default: return null;
    }
  }

  function getISPByIPIP(rawIsp, locArr) {
    const s = (rawIsp || "").toLowerCase();
    const area1 = (locArr[1] || "").toLowerCase();
    if (area1.includes("香港")) {
      if (s.includes("mobile") || s.includes("移动")) return "CMHK";
      if (s.includes("telecom") || s.includes("电信")) return "CTHK";
      return "香港运营商";
    }
    if (area1.includes("澳门")) return "CTM";
    if (/(移动|cmcc)/i.test(s)) return "中国移动";
    if (/(电信|chinanet)/i.test(s)) return "中国电信";
    if (/(联通|unicom)/i.test(s)) return "中国联通";
    return "未知运营商";
  }

  const DEFAULT_ISP = "未知运营商";

  // ===================== 国旗（保留原逻辑，仅nLoc去emoji）=====================
  function getFlagFromIPIP(locArr) {
    const country = locArr[0] || "";
    const map = {
      "中国": "CN", "日本": "JP", "美国": "US", "法国": "FR",
      "德国": "DE", "新加坡": "SG", "英国": "GB", "韩国": "KR",
      "加拿大": "CA", "澳大利亚": "AU", "荷兰": "NL"
    };
    let code = map[country];
    if (!code) {
      if (locArr[1]?.includes("香港")) code = "HK";
      else if (locArr[1]?.includes("澳门")) code = "MO";
      else if (locArr[1]?.includes("台湾")) code = "TW";
    }
    if (!code) return "🌐";
    return String.fromCodePoint(...code.toUpperCase().split('').map(c => 127397 + c.charCodeAt()));
  }

  // ===================== 🔥 获取物理出口（用于奈飞GeoIP融合）=====================
  async function getPhysicalLoc() {
    try {
      const res = await ctx.http.get("https://1.1.1.1/cdn-cgi/trace", { timeout: 2500 });
      const match = res.body?.match(/loc=([A-Z]{2})/);
      return match && match[1] !== "XX" ? match[1] : null;
    } catch {
      return null;
    }
  }

  // ===================== 🔥 新增：整合基础IP信息获取函数 =====================
  async function fetchBaseInfo(globalStart) {
    // 初始化返回数据
    const baseInfo = {
      realTcpDelay: 0,
      apiResponseTime: 0,
      ipData: {},
      pubIp: "—",
      pubLoc: "—",
      pubIsp: DEFAULT_ISP,
      pubASN: "",
      nIp: "—",
      nLoc: "—",
      asnInfo: "—",
      ipinfoCountry: "", // ✅ 新增：ipinfo国家码
      countryCode: "XX"  // 解锁检测用国家码
    };

    // 1. 网络 RTT（HTTPS 真实延迟）
    const pingTask = ctx.http.get("https://1.1.1.1/cdn-cgi/trace", { timeout: 2500 })
      .then(() => { baseInfo.realTcpDelay = Date.now() - globalStart; })
      .catch(() => { baseInfo.realTcpDelay = 0; });

    // 2. 接口延迟（剔除 JSON 解析）
    const ippureTask = ctx.http.get("https://my.ippure.com/v1/info", { timeout: 5000 })
      .then(async (res) => {
        const t0 = Date.now();
        baseInfo.ipData = await res.json();
        const parseTime = Date.now() - t0;
        baseInfo.apiResponseTime = (Date.now() - globalStart) - parseTime;
      })
      .catch(() => { baseInfo.apiResponseTime = 0; });

    // 3. 其他IP信息
    const ipipPromise = ctx.http.get("https://myip.ipip.net/json", {
      headers: { "User-Agent": "Mozilla/5.0" }, timeout: 5000
    }).catch(() => null);

    const ipinfoPromise = ctx.http.get("https://ipinfo.io/json", { timeout: 5000 })
      .catch(() => null);

    // 并行执行
    const [_, __, ipipResRaw, ipinfoResRaw] = await Promise.all([
      pingTask,
      ippureTask,
      ipipPromise,
      ipinfoPromise
    ]);

    // 解析ipip数据
    if (ipipResRaw) {
      try {
        const body = await ipipResRaw.json();
        if (body?.data) {
          baseInfo.pubIp = body.data.ip || "—";
          if (baseInfo.pubIp) {
            baseInfo.pubASN = await ctx.http.get(`https://ipapi.co/${baseInfo.pubIp}/asn/`, { timeout: 3000 })
              .then(r => r.text().then(t => t.trim())).catch(() => "");
          }
          const locArr = Array.isArray(body.data.location) 
            ? body.data.location 
            : (body.data.location || "").split(" ").filter(Boolean);
          baseInfo.pubIsp = getISPByASN(baseInfo.pubASN) || getISPByIPIP(locArr[4] || locArr[3] || "", locArr) || DEFAULT_ISP;
          const flag = getFlagFromIPIP(locArr);
          baseInfo.pubLoc = `${flag} ${locArr[1] || ""} ${locArr[2] || ""}`.trim() || "—";
        }
      } catch (e) {}
    }

    // 解析ipinfo数据（✅ 重点修改：新增ipinfoCountry + 去emoji）
    if (ipinfoResRaw) {
      try {
        const dt = await ipinfoResRaw.json();
        baseInfo.nIp = dt.ip || "—";
        // ✅ 核心：新增ipinfoCountry变量
        baseInfo.ipinfoCountry = (dt.country || "").toUpperCase();
        // ✅ 去emoji依赖：nLoc不再拼接flag
        baseInfo.nLoc = `${dt.region || ""} ${dt.city || ""}`.trim() || "—";
        baseInfo.asnInfo = dt.org || "—";
        // 赋值给解锁检测用的countryCode
        baseInfo.countryCode = baseInfo.ipinfoCountry || "XX";
      } catch (e) {}
    }

    return baseInfo;
  }

  // ===================== 🔥 解锁检测核心逻辑 =====================
  const BASE_UA = "Mozilla/5.0 (iPhone; CPU iPhone OS 17_4 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.4 Mobile/15E148 Safari/604.1";
  // 通用请求头（整合到变量，方便复用）
  const commonHeaders = {
    "User-Agent": BASE_UA,
    "Accept-Language": "ja-JP,ja;q=0.9,en;q=0.8",
    "Referer": "https://www.google.com/"
  };

  // 统一解锁检测函数
  const checkPlatform = async (name, url, isNetflix = false, geoHint = "XX") => {
    try {
      const isAI = name === "GPT" || name === "Gemini";
      
      // 奈飞专属多区域检测逻辑（✅ 核心整合）
      if (isNetflix) {
        // 1️⃣ 多片库检测（内容层）
        const tests = [
          { region: "US", id: "80018499" },
          { region: "JP", id: "70143836" },
          { region: "TW", id: "81215567" },
          { region: "KR", id: "80192098" }
        ];

        const unlocked = [];

        await Promise.all(tests.map(async (t) => {
          try {
            const res = await ctx.http.get(`https://www.netflix.com/title/${t.id}`, {
              timeout: 3500,
              headers: commonHeaders,
              followRedirect: false
            });
            if (res.status === 200) {
              unlocked.push(t.region);
            }
          } catch {}
        }));

        // 2️⃣ 决策逻辑（核心）
        if (unlocked.length === 0) {
          return { name, region: "❌" };
        }

        // 🎯 US优先（最大库）
        if (unlocked.includes("US")) {
          return { name, region: "US" };
        }

        // 🎯 关键：HK / TW 分辨
        if (unlocked.includes("TW")) {
          // 如果Geo倾向HK/SG，但内容是TW → 判定TW解锁
          if (geoHint === "HK" || geoHint === "SG") {
            return { name, region: "TW" };
          }
          return { name, region: "TW" };
        }

        // 🎯 JP / KR
        if (unlocked.includes("JP")) return { name, region: "JP" };
        if (unlocked.includes("KR")) return { name, region: "KR" };

        // fallback
        return { name, region: unlocked[0] };
      }

      // 非奈飞平台检测逻辑（保留原有）
      const res = await ctx.http.get(url, {
        timeout: 4500,
        headers: commonHeaders,
        followRedirect: isAI ? true : false
      });

      // Disney+ 专项逻辑
      if (name === "Disney") {
        const dsRes = await ctx.http.get("https://www.disneyplus.com/welcome/", {
          timeout: 5000,
          headers: commonHeaders,
          followRedirect: true
        });
        const dsUrl = dsRes.url || "";
        const isBlocked = dsUrl.includes("unsupported") || dsUrl.includes("preview") || dsUrl.includes("coming-soon");
        return { name, region: isBlocked ? "❌" : geoHint };
      }

      // AI/其他平台关键词过滤逻辑
      const finalUrl = res.url || "";
      const isBlocked = finalUrl.includes("unsupported") || finalUrl.includes("error") || finalUrl.includes("preview");
      
      // GPT 特殊判定：302 到登录页也算 OK
      if (name === "GPT") {
        if (res.status === 200 || res.status === 302) return { name, region: geoHint };
      }

      if (res.status === 200 && !isBlocked) {
        return { name, region: geoHint };
      }
      return { name, region: "❌" };
    } catch (e) {
      return { name, region: "❌" };
    }
  };

  // ===================== 主逻辑 =====================
  // 基础网络信息
  const d = ctx.device || {};
  const isWifi = !!d.wifi?.ssid;
  let netName = "未连接", netIcon = "antenna.radiowaves.left.and.right";
  if (isWifi) {
    netName = d.wifi.ssid || "Wi‑Fi";
    netIcon = "wifi";
  } else if (d.cellular?.radio) {
    const r = d.cellular.radio.toUpperCase().replace(/\s+/g, "");
    const map = { "GPRS": "2G", "EDGE": "2G", "WCDMA": "3G", "LTE": "4G", "NR": "5G", "NRNSA": "5G" };
    netName = `蜂窝: ${map[r] || r || "5G"}`;
  }

  // 科学计时：独立内部计时
  const globalStart = Date.now();

  // 获取基础IP信息（调用新增的fetchBaseInfo函数）
  const baseInfo = await fetchBaseInfo(globalStart);
  // 获取物理出口（GeoHint）
  const realPhysicalRegion = await getPhysicalLoc();
  // 确定GeoHint（ipinfoCountry优先，物理出口兜底）
  const geoHint = baseInfo.ipinfoCountry || realPhysicalRegion || "XX";

  // 执行解锁检测（传入geoHint）
  const unlockResults = await Promise.all([
    checkPlatform("GPT", "https://chatgpt.com/auth/login", false, geoHint),
    checkPlatform("奈飞", "", true, geoHint), // 奈飞无需传url，isNetflix=true即可
    checkPlatform("TikTok", "https://www.tiktok.com/", false, geoHint),
    checkPlatform("Gemini", "https://gemini.google.com/app", false, geoHint),
    checkPlatform("Disney", "https://www.disneyplus.com", false, geoHint)
  ]);
  const unlockText = unlockResults.map(r => `${r.name} ${r.region}`).join("，");

  // 风险评分（保留原有）
  const risk = baseInfo.ipData.fraudScore;
  let riskTxt = "检测失败", riskColor = C_SUB; 
  if (typeof risk === "number") {
    if (risk < 30) {
      riskTxt = `极高纯净 (${risk})`;
      riskColor = C_GREEN;
    } else if (risk < 60) {
      riskTxt = `中等风险 (${risk})`;
      riskColor = C_YELLOW;
    } else {
      riskTxt = `高风险警告 (${risk})`;
      riskColor = C_RED;
    }
  }

  // IP类型判断（保留原有）
  const ipType = baseInfo.ipData.isResidential === true ? "🏠 住宅" 
    : baseInfo.ipData.isResidential === false ? "🏢 机房" 
    : getIPType(baseInfo.pubIsp, baseInfo.asnInfo);

  // 延迟颜色（保留原有）
  let delayColor = C_SUB;
  if (baseInfo.realTcpDelay > 0) {
    if (baseInfo.realTcpDelay < 150) delayColor = C_GREEN;
    else if (baseInfo.realTcpDelay <= 350) delayColor = C_YELLOW;
    else delayColor = C_RED;
  } else if (baseInfo.apiResponseTime > 0) {
    if (baseInfo.apiResponseTime < 150) delayColor = C_GREEN;
    else if (baseInfo.apiResponseTime <= 350) delayColor = C_YELLOW;
    else delayColor = C_RED;
  }

  // 延迟文本（保留原有）
  const delayText = baseInfo.realTcpDelay > 0 
    ? `${baseInfo.realTcpDelay}ms (网络RTT) / ${baseInfo.apiResponseTime || "—"}ms (接口)`
    : `${baseInfo.apiResponseTime || "—"}ms (接口)`;

  // UI 组件（保留原有）
  const Row = (ic, icCol, label, val, valCol) => ({
    type: "stack", direction: "row", alignItems: "center", padding: [3, 0],
    children: [
      { type: "image", src: `sf-symbol:${ic}`, color: getThemeColor(icCol), width: 12, height: 12 },
      { type: "spacer", length: 5 },
      { type: "text", text: label, font: { size: 10 }, textColor: getThemeColor(C_SUB) },
      { type: "spacer" },
      { type: "text", text: val, font: { size: 10, weight: "medium" }, textColor: getThemeColor(valCol), maxLines: 1 }
    ]
  });

  // 最终返回（保留原有）
  return {
    type: "widget",
    padding: [8, 10],
    backgroundColor: getThemeColor(BG_CARD),
    cornerRadius: 12,
    refreshPolicy: { onNetworkChange: true, onEnter: true, timeout: 10 },
    children: [
      {
        type: "stack", direction: "row", alignItems: "center", padding: [2, 0, 4, 0],
        children: [
          { type: "image", src: `sf-symbol:${netIcon}`, color: getThemeColor(C_BLUE), width:14, height:14 },
          { type: "spacer", length:5 },
          { type: "text", text: netName, font: { size:13, weight:"semibold" }, textColor: getThemeColor(C_TEXT) },
          { type: "spacer" },
          { type: "text", text: delayText, font: { size:10, weight:"medium" }, textColor: getThemeColor(delayColor) }
        ]
      },
      Row("globe", C_BLUE, "直连IP", `${baseInfo.pubIp} (${baseInfo.pubIsp})`, C_TEXT),
      Row("mappin", C_SUB, "位置", baseInfo.pubLoc, C_TEXT),
      Row("paperplane.fill", C_BLUE, "落地IP", `${baseInfo.nIp} ${ipType}`, C_TEXT),
      Row("mappin", C_SUB, "落地地区", baseInfo.nLoc, C_TEXT), // ✅ 已去emoji
      Row("number.square.fill", C_SUB, "ASN", baseInfo.asnInfo, C_TEXT),
      Row("shield.fill", riskColor, "风险评分", riskTxt, riskColor),
      Row("play.tv.fill", C_BLUE, "解锁检测", unlockText, C_TEXT)
    ]
  };
}
