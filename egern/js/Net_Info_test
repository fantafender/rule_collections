export default async function(ctx) {
  // ===================== 样式常量 =====================
  const BG_CARD = { light: '#FFFFFF', dark: '#1C1E1E' };
  const C_TEXT  = { light: '#000000', dark: '#FFFFFF' };
  const C_SUB   = { light: '#6E6E73', dark: '#8E8E93' };
  const C_BLUE  = { light: '#007AFF', dark: '#0A84FF' };
  const C_GREEN = { light: '#34C759', dark: '#30D158' };
  const C_ORANGE= { light: '#FF9500', dark: '#FF9F0A' };
  const C_RED   = { light: '#FF3B30', dark: '#FF453A' };
  const C_YELLOW= { light: '#FFCC00', dark: '#FFD60A' };

  // ===================== 【核心优化】IP类型判断（采纳你的逻辑+补充关键词）=====================
  function getIPType(isp, org) {
    const raw = `${isp} ${org}`.toLowerCase();
    // 住宅宽带（补充多语言/多关键词）
    if (raw.includes('residential') || raw.includes('consumer') || raw.includes('home') || 
        raw.includes('住户') || raw.includes('家庭') || raw.includes('résidentiel') || raw.includes('maison')) {
      return "🏠 住宅宽带";
    }
    // 商业数据中心（补充多语言/多关键词）
    if (raw.includes('datacenter') || raw.includes('hosting') || raw.includes('server') || 
        raw.includes('机房') || raw.includes('服务器') || raw.includes('centre de données') || raw.includes('hébergement')) {
      return "🏢 商业数据中心";
    }
    // 移动基站（补充多语言/多关键词）
    if (raw.includes('mobile') || raw.includes('cellular') || raw.includes('移动') || 
        raw.includes('蜂窝') || raw.includes('mobilette')) {
      return "📶 移动基站";
    }
    // 广播IP（补充多语言/多关键词）
    if (raw.includes('broadcast') || raw.includes('广播') || raw.includes('radiodiffusion')) {
      return "📡 广播 IP";
    }
    // 兜底：固定IP
    return "🌐 固定 IP";
  }

  // ===================== 运营商识别（三层兜底）=====================
  function getISPByASN(asn) {
    const asnCode = (asn || '').trim().replace(/^AS/, '');
    switch (asnCode) {
      case '9231': return 'CMHK';
      case '9381': return 'CTHK';
      case '4609': return 'CTM';
      case '15557': return 'SFR';
      case '12322': return 'Free';
      case '3215': return 'Orange';
      case '5410': return 'Bouygues';
      default: return null;
    }
  }

  function getISPByIPIP(rawIsp, locArr) {
    const s = (rawIsp || '').toLowerCase();
    const area1 = (locArr[1] || '').toLowerCase();

    if (area1.includes('香港')) {
      if (s.includes('mobile') || s.includes('移动')) return 'CMHK';
      if (s.includes('telecom') || s.includes('电信')) return 'CTHK';
      return '香港运营商';
    }
    if (area1.includes('澳门')) return 'CTM';

    if (area1.includes('法兰西岛') || area1.includes('法国') || area1.includes('巴黎')) {
      if (s.includes('sfr')) return 'SFR';
      if (s.includes('orange')) return 'Orange';
      if (s.includes('free')) return 'Free';
      if (s.includes('bouygues')) return 'Bouygues';
      return '法国运营商';
    }

    if (/(移动|cmcc)/i.test(s)) return '中国移动';
    if (/(电信|chinanet)/i.test(s)) return '中国电信';
    if (/(联通|unicom)/i.test(s)) return '中国联通';
    return '未知运营商';
  }

  const DEFAULT_ISP = '未知运营商';

  // ===================== 国旗逻辑（支持所有主流国家）=====================
  function getFlagFromIPIP(locArr) {
    const country = locArr[0] || "";
    const countryCodeMap = {
      "中国": "CN", "日本": "JP", "美国": "US", "法国": "FR",
      "德国": "DE", "新加坡": "SG", "英国": "GB", "韩国": "KR",
      "加拿大": "CA", "澳大利亚": "AU", "荷兰": "NL", "意大利": "IT",
      "西班牙": "ES", "俄罗斯": "RU", "印度": "IN", "巴西": "BR"
    };

    let code = countryCodeMap[country];
    // 港澳台特殊处理
    if (!code) {
      if (locArr[1]?.includes('香港')) code = 'HK';
      else if (locArr[1]?.includes('澳门')) code = 'MO';
      else if (locArr[1]?.includes('台湾')) code = 'TW';
    }
    // 法国运营商兜底
    if (!code && locArr.length) {
      const isp = getISPByIPIP('', locArr);
      if (['SFR', 'Free', 'Orange', 'Bouygues', '法国运营商'].includes(isp)) {
        code = 'FR';
      }
    }
    if (!code) return "🌐";
    return String.fromCodePoint(...code.toUpperCase().split('').map(c => 127397 + c.charCodeAt()));
  }

  // ===================== 基础配置 =====================
  const cityMap = { tokyo: '东京', osaka: '大阪', kyoto: '京都' };
  const regionMap = { tokyo: '东京都', osaka: '大阪府' };

  // 预留1.2秒获取网络参数
  await new Promise(resolve => setTimeout(resolve, 1200));

  const d = ctx.device || {};
  const isWifi = !!d.wifi?.ssid;

  let netName = "未连接", netIcon = "antenna.radiowaves.left.and.right";
  if (isWifi) {
    netName = d.wifi.ssid || "Wi‑Fi";
    netIcon = "wifi";
  } else if (d.cellular?.radio) {
    const radioMap = {
      "GPRS": "2.5G", "EDGE": "2.75G", "WCDMA": "3G",
      "LTE": "LTE (4G)", "NR": "5G (SA)", "NRNSA": "5G (NSA)"
    };
    const rawRadio = d.cellular.radio?.toUpperCase().replace(/\s+/g, "") || "";
    netName = `蜂窝: ${radioMap[rawRadio] || rawRadio || "5G"}`;
  }

  const localIp = d.ipv4?.address || "—";

  // ===================== 并行请求（性能优化）=====================
  let asnPromise = Promise.resolve("");
  const ipipPromise = ctx.http.get('https://myip.ipip.net/json', {
    headers: { 'User-Agent': 'Mozilla/5.0' }, 
    timeout: 5000,
    retry: 1
  }).then(async (res) => {
    const body = await res.json();
    if (body?.data?.ip) {
      asnPromise = ctx.http.get(`https://ipapi.co/${body.data.ip}/asn/`, { 
        timeout: 3000,
        retry: 1
      }).then(res => res.text().then(t => t.trim())).catch(() => "");
    }
    return body;
  }).catch(() => ({}));

  const ipinfoPromise = ctx.http.get('https://ipinfo.io/json', { 
    timeout: 5000,
    retry: 1
  }).catch(() => ({}));

  // 延迟计算（明确为接口响应时间）
  let ipData = {}, apiResponseTime = 0;
  const ippurePromise = (async () => {
    try {
      const start = Date.now();
      const r = await ctx.http.get('https://my.ippure.com/v1/info', { 
        timeout: 5000,
        retry: 1
      });
      apiResponseTime = Date.now() - start;
      ipData = await r.json();
    } catch (e) {
      ipData = {};
      apiResponseTime = 0;
    }
  })();

  // 等待所有请求完成
  const [ipipRes, ipinfoRes] = await Promise.allSettled([ipipPromise, ipinfoPromise]);
  await ippurePromise;

  // ===================== 直连IP解析 =====================
  let pubIp = "—", pubLoc = "—", pubIsp = DEFAULT_ISP, pubASN = "";
  pubASN = await asnPromise || "";

  if (ipipRes.status === 'fulfilled' && ipipRes.value?.data) {
    try {
      const body = ipipRes.value;
      pubIp = body.data.ip || "—";
      
      // 兼容location数组/字符串格式
      const locRaw = body.data.location;
      const locArr = Array.isArray(locRaw) 
        ? locRaw 
        : (locRaw || '').split(' ').filter(item => item);
      
      const rawIspFromIPIP = locArr[4] || locArr[3] || '';
      pubIsp = getISPByASN(pubASN) || getISPByIPIP(rawIspFromIPIP, locArr) || DEFAULT_ISP;

      const flag = getFlagFromIPIP(locArr);
      pubLoc = `${flag} ${locArr[1] || ""} ${locArr[2] || ""}`.trim() || "—";
    } catch (e) {
      console.log('ipip解析失败，使用默认值');
    }
  }

  // ===================== 落地IP解析 =====================
  let nIp = "—", nLoc = "—", asnInfo = "—";
  if (ipinfoRes.status === 'fulfilled') {
    try {
      const dt = await ipinfoRes.value.json();
      nIp = dt.ip || "—";
      const code = dt.country || "";
      const flag = code ? String.fromCodePoint(...code.toUpperCase().split('').map(c => 127397 + c.charCodeAt())) : "🌐";
      const cityEn = (dt.city || "").toLowerCase();
      const regionEn = (dt.region || "").toLowerCase();
      const city = cityMap[cityEn] || dt.city || "";
      const region = regionMap[regionEn] || dt.region || "";
      nLoc = city === region ? `${flag} ${city}` : `${flag} ${region} ${city}`;
      asnInfo = dt.org || "—";
    } catch (e) {}
  }

  // ===================== 风险与IP类型判断（融合最优逻辑）=====================
  // 优先用接口精准判断，失效时用getIPType兜底
  const nativeText = ipData.isResidential === true
    ? "🏠 住宅" 
    : ipData.isResidential === false 
      ? "🏢 机房" 
      : getIPType(pubIsp, asnInfo); // 采纳你的逻辑作为兜底

  const nodeIpWithNative = `${nIp} ${nativeText}`;

  const risk = ipData.fraudScore;
  let riskTxt = "…", riskCol = C_SUB, riskIcon = "clock";
  if (risk != null) {
    if (risk >= 80) { riskTxt = `极高风险 ${risk}`; riskCol = C_RED; riskIcon = "xmark.shield.fill"; }
    else if (risk >= 70) { riskTxt = `高风险 ${risk}`; riskCol = C_ORANGE; riskIcon = "exclamationmark.shield.fill"; }
    else if (risk >= 40) { riskTxt = `中风险 ${risk}`; riskCol = C_YELLOW; riskIcon = "exclamationmark.shield.fill"; }
    else { riskTxt = `纯净 ${risk}`; riskCol = C_GREEN; riskIcon = "checkmark.shield.fill"; }
  }

  // 延迟显示（明确标注）
  const delayText = apiResponseTime > 0 ? `${apiResponseTime}ms (接口)` : "…";
  const delayColor = apiResponseTime > 300 ? C_RED : apiResponseTime > 100 ? C_YELLOW : C_GREEN;

  // ===================== UI组件 =====================
  const Row = (ic, icCol, label, val, valCol) => ({
    type: 'stack', direction: 'row', alignItems: 'center', padding: [3, 0],
    children: [
      { type: 'image', src: `sf-symbol:${ic}`, color: icCol, width: 12, height: 12 },
      { type: 'spacer', length: 5 },
      { type: 'text', text: label, font: { size: 10 }, textColor: C_SUB },
      { type: 'spacer' },
      { type: 'text', 
        text: val, 
        font: { size: 10, weight: 'medium' }, 
        textColor: valCol, 
        maxLines: 1, 
        lineBreakMode: 'truncatedTail' 
      }
    ]
  });

  // ===================== 最终返回 =====================
  return {
    type: 'widget',
    padding: [8, 10],
    backgroundColor: BG_CARD,
    cornerRadius: 12,
    refreshPolicy: { 
      onNetworkChange: true,
      onEnter: true,
      timeout: 10
    },
    children: [
      {
        type: 'stack', direction: 'row', alignItems: 'center', padding: [2,0,4,0],
        children: [
          { type: 'image', src: `sf-symbol:${netIcon}`, color: C_BLUE, width:14, height:14 },
          { type: 'spacer', length:5 },
          { type: 'text', text: netName, font: { size:13, weight:'semibold' }, textColor: C_TEXT },
          { type: 'spacer' },
          { type: 'text', text: delayText, font: { size:11, weight:'medium' }, textColor: delayColor }
        ]
      },
      Row("iphone", C_GREEN, "内网IP", localIp, C_TEXT),
      Row("globe", C_BLUE, "直连IP", `${pubIp} (${pubIsp})`, C_TEXT),
      Row("mappin", C_SUB, "位置", pubLoc, C_TEXT),
      Row("paperplane.fill", C_BLUE, "落地IP", nodeIpWithNative, C_TEXT),
      Row("mappin", C_SUB, "落地", nLoc, C_TEXT),
      Row("number.square.fill", C_SUB, "ASN", asnInfo, C_TEXT),
      Row(riskIcon, riskCol, "风险", riskTxt, riskCol),
    ]
  };
}
