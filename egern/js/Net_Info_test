/**
 * 📌 稳定并行版 · 不丢数据 · 不空白 · 速度快
 */
export default async function(ctx) => {
  const BG_CARD = { light: '#FFFFFF', dark: '#1C1E1E' };
  const C_TEXT  = { light: '#000000', dark: '#FFFFFF' };
  const C_SUB   = { light: '#6E6E73', dark: '#8E8E93' };
  const C_BLUE  = { light: '#007AFF', dark: '#0A84FF' };
  const C_GREEN = { light: '#34C759', dark: '#30D158' };
  const C_ORANGE= { light: '#FF9500', dark: '#FF9F0A' };
  const C_RED   = { light: '#FF3B30', dark: '#FF453A' };
  const C_YELLOW= { light: '#FFCC00', dark: '#FFD60A' };

  function getISPByASN(asn) {
    const asnCode = (asn || '').trim().replace(/^AS/, '');
    switch (asnCode) {
      case '9231': return 'CMHK';
      case '9381': return 'CTHK';
      case '4609': return 'CTM';
      case '15557': return 'SFR';
      case '12322': return 'Free';
      case '3215': return 'Orange';
      case '5410': return 'Bouygues';
      default: return null;
    }
  }

  function getISPByIPIP(rawIsp, locArr) {
    const s = (rawIsp || '').toLowerCase();
    const area1 = (locArr[1] || '').toLowerCase();

    if (area1.includes('香港')) {
      if (s.includes('mobile') || s.includes('移动')) return 'CMHK';
      if (s.includes('telecom') || s.includes('电信')) return 'CTHK';
      return '香港运营商';
    }
    if (area1.includes('澳门')) return 'CTM';

    if (area1.includes('法兰西岛') || area1.includes('法国') || area1.includes('巴黎')) {
      if (s.includes('sfr')) return 'SFR';
      if (s.includes('orange')) return 'Orange';
      if (s.includes('free')) return 'Free';
      if (s.includes('bouygues')) return 'Bouygues';
      return '法国运营商';
    }

    if (/(移动|cmcc)/i.test(s)) return '中国移动';
    if (/(电信|chinanet)/i.test(s)) return '中国电信';
    if (/(联通|unicom)/i.test(s)) return '中国联通';
    return '未知运营商';
  }

  const DEFAULT_ISP = '未知运营商';
  const cityMap = { tokyo: '东京', osaka: '大阪', kyoto: '京都' };
  const regionMap = { tokyo: '东京都', osaka: '大阪府' };

  await new Promise(r => setTimeout(r, 300));

  const d = ctx.device || {};
  let netName = "未连接", netIcon = "antenna.radiowaves.left.and.right";
  const localIp = d.ipv4?.address || "—";

  if (d.wifi?.ssid) {
    netName = d.wifi.ssid;
    netIcon = "wifi";
  } else if (d.cellular?.radio) {
    const radioMap = {
      "GPRS": "2.5G", "EDGE": "2.75G", "WCDMA": "3G",
      "LTE": "LTE (4G)", "NR": "5G (SA)", "NRNSA": "5G (NSA)"
    };
    const rawRadio = d.cellular.radio?.toUpperCase().replace(/\s+/g, "") || "";
    netName = `蜂窝: ${radioMap[rawRadio] || rawRadio || "5G"}`;
  }

  // ===================== 真正安全的并行请求 =====================
  const fetchWithCatch = (url, opts) => 
    ctx.http.get(url, opts).catch(() => ({ json: async () => ({}), text: async () => "" }));

  const task1 = fetchWithCatch('https://myip.ipip.net/json', {
    headers: { 'User-Agent': 'Mozilla/5.0' }, timeout: 4000
  });

  const task2 = fetchWithCatch('https://ipinfo.io/json', { timeout: 4000 });
  const task3 = fetchWithCatch('https://my.ippure.com/v1/info', { timeout: 4000 });

  // 一起等所有结果
  const [resIpip, resIpinfo, resIppure] = await Promise.all([task1, task2, task3]);

  // 直连IP
  let pubIp = "—", pubLoc = "—", pubIsp = DEFAULT_ISP, pubASN = "";
  const body = await resIpip.json().catch(() => ({}));
  if (body?.data) {
    pubIp = body.data.ip || "—";
    const locArr = body.data.location || [];
    const rawIspFromIPIP = locArr[4] || locArr[3] || '';

    // ASN
    try {
      const asnRes = await ctx.http.get(`https://ipapi.co/${pubIp}/asn/`, { timeout: 3000 });
      pubASN = (await asnRes.text()).trim();
    } catch {}

    pubIsp = getISPByASN(pubASN) || getISPByIPIP(rawIspFromIPIP, locArr) || DEFAULT_ISP;

    let countryFlag = '🇨🇳';
    if (locArr[1]?.includes('法兰西岛') || locArr[1]?.includes('法国') || 
        ['SFR','Orange','Free','Bouygues','法国运营商'].includes(pubIsp)) {
      countryFlag = '🇫🇷';
    } else if (locArr[1]?.includes('香港')) {
      countryFlag = '🇭🇰';
    } else if (locArr[1]?.includes('澳门')) {
      countryFlag = '🇲🇴';
    } else if (locArr[0] !== '中国') {
      countryFlag = '🌐';
    }
    pubLoc = `${countryFlag} ${locArr[1] || ""} ${locArr[2] || ""}`.trim() || "—";
  }

  // 落地IP
  let nIp = "—", nLoc = "—", asnInfo = "—";
  const dt = await resIpinfo.json().catch(() => ({}));
  if (dt) {
    nIp = dt.ip || "—";
    const code = dt.country || "";
    const flag = code ? String.fromCodePoint(...code.toUpperCase().split('').map(c => 127397 + c.charCodeAt())) : "🌐";
    const cityEn = (dt.city || "").toLowerCase();
    const regionEn = (dt.region || "").toLowerCase();
    const city = cityMap[cityEn] || dt.city || "";
    const region = regionMap[regionEn] || dt.region || "";
    nLoc = city === region ? `${flag} ${city}` : `${flag} ${region} ${city}`;
    asnInfo = dt.org || "—";
  }

  // 风险
  let ipData = {}, costTime = 0;
  try {
    const start = Date.now();
    ipData = await resIppure.json().catch(() => ({}));
    costTime = Date.now() - start;
  } catch {}

  const nativeText = ipData.isResidential
    ? "🏠 住宅" : ipData.isResidential === false ? "🏢 机房" : "⟳ 检测中";
  const nodeIpWithNative = `${nIp} ${nativeText}`;

  const risk = ipData.fraudScore;
  let riskTxt = "…", riskCol = C_SUB, riskIcon = "clock";
  if (risk != null) {
    if (risk >= 80) { riskTxt = `极高风险 ${risk}`; riskCol = C_RED; riskIcon = "xmark.shield.fill"; }
    else if (risk >= 70) { riskTxt = `高风险 ${risk}`; riskCol = C_ORANGE; riskIcon = "exclamationmark.shield.fill"; }
    else if (risk >= 40) { riskTxt = `中风险 ${risk}`; riskCol = C_YELLOW; riskIcon = "exclamationmark.shield.fill"; }
    else { riskTxt = `纯净 ${risk}`; riskCol = C_GREEN; riskIcon = "checkmark.shield.fill"; }
  }

  const delayText = costTime > 0 ? `${costTime}ms` : "…";
  const delayColor = costTime > 300 ? C_RED : costTime > 100 ? C_YELLOW : C_GREEN;

  const Row = (ic, icCol, label, val, valCol) => ({
    type: 'stack', direction: 'row', alignItems: 'center', padding: [3, 0],
    children: [
      { type: 'image', src: `sf-symbol:${ic}`, color: icCol, width: 12, height: 12 },
      { type: 'spacer', length: 5 },
      { type: 'text', text: label, font: { size: 10 }, textColor: C_SUB },
      { type: 'spacer' },
      { type: 'text', 
        text: val, 
        font: { size: 10, weight: 'medium' }, 
        textColor: valCol, 
        maxLines: 1, 
        lineBreakMode: 'truncatedTail' 
      }
    ]
  });

  return {
    type: 'widget',
    padding: [8, 10],
    backgroundColor: BG_CARD,
    cornerRadius: 12,
    refreshPolicy: { onNetworkChange: true, onEnter: true, timeout: 10 },
    children: [
      {
        type: 'stack', direction: 'row', alignItems: 'center', padding: [2,0,4,0],
        children: [
          { type: 'image', src: `sf-symbol:${netIcon}`, color: C_BLUE, width:14, height:14 },
          { type: 'spacer', length:5 },
          { type: 'text', text: netName, font: { size:13, weight:'semibold' }, textColor: C_TEXT },
          { type: 'spacer' },
          { type: 'text', text: delayText, font: { size:12, weight:'medium' }, textColor: delayColor }
        ]
      },
      Row("iphone", C_GREEN, "内网IP", localIp, C_TEXT),
      Row("globe", C_BLUE, "直连IP", `${pubIp} (${pubIsp})`, C_TEXT),
      Row("mappin", C_SUB, "位置", pubLoc, C_TEXT),
      Row("paperplane.fill", C_BLUE, "落地IP", nodeIpWithNative, C_TEXT),
      Row("mappin", C_SUB, "落地", nLoc, C_TEXT),
      Row("number.square.fill", C_SUB, "ASN", asnInfo, C_TEXT),
      Row(riskIcon, riskCol, "风险", riskTxt, riskCol),
    ]
  };
}
