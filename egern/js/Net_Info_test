      const inSupportedLocation = gqlJson?.extensions?.sdk?.session?.inSupportedLocation;

      // 4) preview/unavailable 检测（按 Bash：看最终 URL 是否含 preview + unavailable）
      const webRes = await ctx.http.get("https://disneyplus.com", {
        timeout: 10000,
        headers: commonHeaders,
        followRedirect: true
      }).catch(() => null);
      const finalUrl = webRes?.url || "";
      const isUnavailable = finalUrl.includes("preview") && finalUrl.includes("unavailable");

      // 5) 完全按 Bash 分支映射到 UI 文本
      if (region === "JP") return "JP";
      if (region && inSupportedLocation === false && !isUnavailable) return "⏳"; // pending
      if (region && isUnavailable) return "❌";
      if (region && inSupportedLocation === true) return region;
      if (!region) return "❌";
      return "❌";
    } catch {
      return "❌";
    }
  }

  // 统一解锁检测函数
  const checkPlatform = async (name, url, isNetflix = false, geoHint = "XX") => {
    try {
      const isAI = name === "GPT" || name === "Gemini";
      
      // 奈飞解锁检测逻辑（✅ Bash风格）
      if (isNetflix) {
        const resultText = await checkNetflix(ctx, geoHint);
        return { name, region: resultText };
      }

      // TikTok 解锁检测（按 reference1 思路）
      if (name === "TikTok") {
        const resultText = await checkTikTok(ctx);
        return { name, region: resultText };
      }

      // ChatGPT（GPT）检测：按 checkref2 Bash 版逻辑
      if (name === "GPT") {
        const resultText = await checkChatGPT(ctx);
        return { name, region: resultText };
      }

      // 非奈飞/非 GPT 平台检测逻辑（保留原有）
      const res = await ctx.http.get(url, {
        timeout: 4500,
        headers: commonHeaders,
        followRedirect: isAI ? true : false
      });

      // Disney+ 专项逻辑（完全按 reference1 Bash 版）
      if (name === "Disney") {
        const resultText = await checkDisneyPlusFull(ctx);
        return { name, region: resultText };
      }

      // AI/其他平台关键词过滤逻辑
      const finalUrl = res.url || "";
      const isBlocked = finalUrl.includes("unsupported") || finalUrl.includes("error") || finalUrl.includes("preview");

      if (res.status === 200 && !isBlocked) {
        return { name, region: geoHint };
      }
      return { name, region: "❌" };
    } catch (e) {
      return { name, region: "❌" };
    }
  };

  // ===================== 主逻辑 =====================
  // 基础网络信息
  const d = ctx.device || {};
  const isWifi = !!d.wifi?.ssid;
  let netName = "未连接", netIcon = "antenna.radiowaves.left.and.right";
  if (isWifi) {
    netName = d.wifi.ssid || "Wi‑Fi";
    netIcon = "wifi";
  } else if (d.cellular?.radio) {
    const r = d.cellular.radio.toUpperCase().replace(/\s+/g, "");
    const map = { "GPRS": "2G", "EDGE": "2G", "WCDMA": "3G", "LTE": "4G", "NR": "5G", "NRNSA": "5G" };
    netName = `蜂窝: ${map[r] || r || "5G"}`;
  }

  // 科学计时：独立内部计时
  const globalStart = Date.now();

  // 获取基础IP信息（调用新增的fetchBaseInfo函数）
  const baseInfo = await fetchBaseInfo(globalStart);
  // 获取物理出口（GeoHint）
  const realPhysicalRegion = await getPhysicalLoc();
  // 确定GeoHint（ipinfoCountry优先，物理出口兜底）
  const geoHint = baseInfo.ipinfoCountry || realPhysicalRegion || "XX";

  // 执行解锁检测（传入geoHint）
  const unlockResults = await Promise.all([
    checkPlatform("GPT", "https://chatgpt.com/auth/login", false, geoHint),
    checkPlatform("Gemini", "https://gemini.google.com/app", false, geoHint),
    checkPlatform("奈飞", "", true, geoHint), // 奈飞无需传url，isNetflix=true即可
    checkPlatform("TikTok", "https://www.tiktok.com/", false, geoHint),
    checkPlatform("Disney", "https://www.disneyplus.com", false, geoHint)
  ]);
  const unlockText = unlockResults.map(r => `${r.name} ${r.region}`).join("，");

  // 风险评分（保留原有）
  const risk = baseInfo.ipData.fraudScore;
  let riskTxt = "检测失败", riskColor = C_SUB; 
  if (typeof risk === "number") {
    if (risk < 30) {
      riskTxt = `极高纯净 (${risk})`;
      riskColor = C_GREEN;
    } else if (risk < 60) {
      riskTxt = `中等风险 (${risk})`;
      riskColor = C_YELLOW;
    } else {
      riskTxt = `高风险警告 (${risk})`;
      riskColor = C_RED;
    }
  }

  // IP类型判断（保留原有）
  const ipType = baseInfo.ipData.isResidential === true ? "🏠 住宅" 
    : baseInfo.ipData.isResidential === false ? "🏢 机房" 
    : getIPType(baseInfo.pubIsp, baseInfo.asnInfo);

  // 延迟颜色（保留原有）
  let delayColor = C_SUB;
  if (baseInfo.realTcpDelay > 0) {
    if (baseInfo.realTcpDelay < 150) delayColor = C_GREEN;
    else if (baseInfo.realTcpDelay <= 350) delayColor = C_YELLOW;
    else delayColor = C_RED;
  } else if (baseInfo.apiResponseTime > 0) {
    if (baseInfo.apiResponseTime < 150) delayColor = C_GREEN;
    else if (baseInfo.apiResponseTime <= 350) delayColor = C_YELLOW;
    else delayColor = C_RED;
  }

  // 延迟文本（保留原有）
  const delayText = baseInfo.realTcpDelay > 0 
    ? `${baseInfo.realTcpDelay}ms (网络RTT) / ${baseInfo.apiResponseTime || "—"}ms (接口)`
    : `${baseInfo.apiResponseTime || "—"}ms (接口)`;

  // UI 组件（保留原有）
  const Row = (ic, icCol, label, val, valCol) => ({
    type: "stack", direction: "row", alignItems: "center", padding: [3, 0],
    children: [
      { type: "image", src: `sf-symbol:${ic}`, color: getThemeColor(icCol), width: 12, height: 12 },
      { type: "spacer", length: 5 },
      { type: "text", text: label, font: { size: 10 }, textColor: getThemeColor(C_SUB) },
      { type: "spacer" },
      { type: "text", text: val, font: { size: 10, weight: "medium" }, textColor: getThemeColor(valCol), maxLines: 1 }
    ]
  });

  // 最终返回（保留原有）
  return {
    type: "widget",
    padding: [8, 10],
    backgroundColor: getThemeColor(BG_CARD),
    cornerRadius: 12,
    refreshPolicy: { onNetworkChange: true, onEnter: true, timeout: 10 },
    children: [
      {
        type: "stack", direction: "row", alignItems: "center", padding: [2, 0, 4, 0],
        children: [
          { type: "image", src: `sf-symbol:${netIcon}`, color: getThemeColor(C_BLUE), width:14, height:14 },
          { type: "spacer", length:5 },
          { type: "text", text: netName, font: { size:13, weight:"semibold" }, textColor: getThemeColor(C_TEXT) },
          { type: "spacer" },
          { type: "text", text: delayText, font: { size:10, weight:"medium" }, textColor: getThemeColor(delayColor) }
        ]
      },
      Row("globe", C_BLUE, "直连IP", `${baseInfo.pubIp} (${baseInfo.pubIsp})`, C_TEXT),
      Row("mappin", C_SUB, "位置", baseInfo.pubLoc, C_TEXT),
      Row("paperplane.fill", C_BLUE, "落地IP", `${baseInfo.nIp} ${ipType}`, C_TEXT),
      Row("mappin", C_SUB, "落地地区", baseInfo.nLoc, C_TEXT), // ✅ 已去emoji
      Row("number.square.fill", C_SUB, "ASN", baseInfo.asnInfo, C_TEXT),
      Row("shield.fill", riskColor, "风险评分", riskTxt, riskColor),
      Row("play.tv.fill", C_BLUE, "解锁", unlockText, C_TEXT)
    ]
  };
}
