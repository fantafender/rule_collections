/**
 * 📌 Egern IP 质量 & 解锁检测 Widget — 优化版
 *
 * 优化内容：
 *  1. 延迟测量独立打点，不再依赖 globalStart 偏移
 *  2. 最大化并行：fetchBaseInfo / getPhysicalLoc / 解锁检测尽可能并行
 *  3. 移除未使用的 DNS 多路查询代码（原来查了但丢弃结果）
 *  4. Netflix: 增加 og:video 判定，区分全解锁 / 仅自制剧 / 受限
 *  5. ChatGPT: 增加 "WEB" 中间状态（Web 可用但 APP 受限）
 *  6. TikTok: 增加 store_region API 作为主要检测手段
 *  7. Gemini: 修正正则，删除过于宽松的 fallback
 *  8. Disney+: 修复 checkPlatform 里的冗余请求
 *  9. 核心检测增加 1 次重试
 * 10. 各处细节健壮性修复
 */
export default async function (ctx) {
  // ===================== 样式常量 =====================
  const BG_CARD  = { light: '#FFFFFF', dark: '#1C1E1E' };
  const C_TEXT   = { light: '#000000', dark: '#FFFFFF' };
  const C_SUB    = { light: '#6E6E73', dark: '#8E8E93' };
  const C_BLUE   = { light: '#007AFF', dark: '#0A84FF' };
  const C_GREEN  = { light: '#34C759', dark: '#30D158' };
  const C_YELLOW = { light: '#FF9F0A', dark: '#FF9F0A' };
  const C_RED    = { light: '#FF3B30', dark: '#FF453A' };

  const getThemeColor = (colorObj) => {
    const isDark = ctx?.device?.colorScheme === 'dark' || false;
    return isDark ? colorObj.dark : colorObj.light;
  };

  // ===================== 通用 UA & Headers =====================
  const BASE_UA = "Mozilla/5.0 (iPhone; CPU iPhone OS 17_4 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.4 Mobile/15E148 Safari/604.1";
  const commonHeaders = {
    "User-Agent": BASE_UA,
    "Accept-Language": "ja-JP,ja;q=0.9,en;q=0.8",
    "Referer": "https://www.google.com/"
  };

  // ===================== 工具函数 =====================
  const DEFAULT_ISP = "未知运营商";

  // 已知国家码白名单（用于 Gemini 校验）
  const KNOWN_COUNTRY_CODES = new Set([
    "AD","AE","AF","AG","AI","AL","AM","AO","AR","AS","AT","AU","AW","AX","AZ",
    "BA","BB","BD","BE","BF","BG","BH","BI","BJ","BL","BM","BN","BO","BR","BS",
    "BT","BW","BY","BZ","CA","CC","CD","CF","CG","CH","CI","CK","CL","CM","CN",
    "CO","CR","CU","CV","CW","CX","CY","CZ","DE","DJ","DK","DM","DO","DZ","EC",
    "EE","EG","ER","ES","ET","FI","FJ","FK","FM","FO","FR","GA","GB","GD","GE",
    "GF","GG","GH","GI","GL","GM","GN","GP","GQ","GR","GT","GU","GW","GY","HK",
    "HN","HR","HT","HU","ID","IE","IL","IM","IN","IO","IQ","IR","IS","IT","JE",
    "JM","JO","JP","KE","KG","KH","KI","KM","KN","KP","KR","KW","KY","KZ","LA",
    "LB","LC","LI","LK","LR","LS","LT","LU","LV","LY","MA","MC","MD","ME","MF",
    "MG","MH","MK","ML","MM","MN","MO","MP","MQ","MR","MS","MT","MU","MV","MW",
    "MX","MY","MZ","NA","NC","NE","NF","NG","NI","NL","NO","NP","NR","NU","NZ",
    "OM","PA","PE","PF","PG","PH","PK","PL","PM","PN","PR","PS","PT","PW","PY",
    "QA","RE","RO","RS","RU","RW","SA","SB","SC","SD","SE","SG","SH","SI","SK",
    "SL","SM","SN","SO","SR","SS","ST","SV","SX","SY","SZ","TC","TD","TF","TG",
    "TH","TJ","TK","TL","TM","TN","TO","TR","TT","TV","TW","TZ","UA","UG","US",
    "UY","UZ","VA","VC","VE","VG","VI","VN","VU","WF","WS","YE","YT","ZA","ZM","ZW"
  ]);

  /** 带重试的 GET 请求 */
  async function httpGetRetry(url, opts = {}, retries = 1) {
    for (let i = 0; i <= retries; i++) {
      try {
        return await ctx.http.get(url, opts);
      } catch (e) {
        if (i === retries) throw e;
      }
    }
  }

  /** 带重试的 POST 请求 */
  async function httpPostRetry(url, opts = {}, retries = 1) {
    for (let i = 0; i <= retries; i++) {
      try {
        return await ctx.http.post(url, opts);
      } catch (e) {
        if (i === retries) throw e;
      }
    }
  }

  /** 安全读取响应 body */
  const readBody = async (r) => {
    if (!r) return "";
    if (typeof r.body === "string" && r.body.length) return r.body;
    if (typeof r.text === "function") {
      try { return (await r.text()) || ""; } catch { return ""; }
    }
    return "";
  };

  // ===================== IP 类型判断 =====================
  function getIPType(isp, org) {
    const raw = `${isp} ${org}`.toLowerCase();
    if (/residential|consumer|home|住户|家庭/.test(raw)) return "🏠 住宅";
    if (/datacenter|hosting|server|机房|数据中心/.test(raw)) return "🏢 机房";
    if (/mobile|cellular|移动|蜂窝/.test(raw)) return "📶 移动";
    return "🌐 固定IP";
  }

  // ===================== 运营商识别 =====================
  function getISPByASN(asn) {
    const code = (asn || "").trim().replace(/^AS/, "");
    const map = { "9231": "CMHK", "9381": "CTHK", "4609": "CTM" };
    return map[code] || null;
  }

  function getISPByIPIP(rawIsp, locArr) {
    const s = (rawIsp || "").toLowerCase();
    const area1 = (locArr[1] || "").toLowerCase();
    if (area1.includes("香港")) {
      if (/mobile|移动/.test(s)) return "CMHK";
      if (/telecom|电信/.test(s)) return "CTHK";
      return "香港运营商";
    }
    if (area1.includes("澳门")) return "CTM";
    if (/(移动|cmcc)/i.test(s)) return "中国移动";
    if (/(电信|chinanet)/i.test(s)) return "中国电信";
    if (/(联通|unicom)/i.test(s)) return "中国联通";
    return DEFAULT_ISP;
  }

  // ===================== 国旗工具 =====================
  function codeToFlag(code) {
    if (!code || code === "XX" || code.length !== 2 || !/^[A-Z]{2}$/.test(code)) return "🌐";
    return String.fromCodePoint(...code.split('').map(c => 127397 + c.charCodeAt()));
  }

  function getFlagFromIPIP(locArr) {
    const country = locArr[0] || "";
    const map = {
      "中国": "CN", "日本": "JP", "美国": "US", "法国": "FR",
      "德国": "DE", "新加坡": "SG", "英国": "GB", "韩国": "KR",
      "加拿大": "CA", "澳大利亚": "AU", "荷兰": "NL"
    };
    let code = map[country];
    if (!code) {
      if (locArr[1]?.includes("香港")) code = "HK";
      else if (locArr[1]?.includes("澳门")) code = "MO";
      else if (locArr[1]?.includes("台湾")) code = "TW";
    }
    return code ? codeToFlag(code) : "🌐";
  }

  // ===================== 获取物理出口 =====================
  async function getPhysicalLoc() {
    try {
      const res = await ctx.http.get("https://1.1.1.1/cdn-cgi/trace", { timeout: 2500 });
      const m = res.body?.match(/loc=([A-Z]{2})/);
      return m && m[1] !== "XX" ? m[1] : null;
    } catch { return null; }
  }

  // ===================== 基础 IP 信息获取（优化并行） =====================
  async function fetchBaseInfo() {
    const baseInfo = {
      realTcpDelay: 0,
      apiResponseTime: 0,
      ipData: {},
      pubIp: "—", pubLoc: "—", pubIsp: DEFAULT_ISP, pubASN: "",
      nIp: "—", nLoc: "—", asnInfo: "—",
      ipinfoCountry: "", countryCode: "XX"
    };

    // 1) 网络 RTT —— 独立打点
    const pingTask = (async () => {
      const t0 = Date.now();
      try {
        await ctx.http.get("https://1.1.1.1/cdn-cgi/trace", { timeout: 2500 });
        baseInfo.realTcpDelay = Date.now() - t0;
      } catch { baseInfo.realTcpDelay = 0; }
    })();

    // 2) ippure 风险评分接口 —— 独立打点
    const ippureTask = (async () => {
      const t0 = Date.now();
      try {
        const res = await ctx.http.get("https://my.ippure.com/v1/info", { timeout: 5000 });
        baseInfo.ipData = await res.json();
        baseInfo.apiResponseTime = Date.now() - t0;
      } catch { baseInfo.apiResponseTime = 0; }
    })();

    // 3) ipip
    const ipipPromise = ctx.http.get("https://myip.ipip.net/json", {
      headers: { "User-Agent": "Mozilla/5.0" }, timeout: 5000
    }).catch(() => null);

    // 4) ipinfo
    const ipinfoPromise = ctx.http.get("https://ipinfo.io/json", { timeout: 5000 }).catch(() => null);

    // 并行执行所有
    const [, , ipipRes, ipinfoRes] = await Promise.all([pingTask, ippureTask, ipipPromise, ipinfoPromise]);

    // 解析 ipip + ASN（ASN 查询不再阻塞 ipip 解析主流程）
    let pubIpForASN = null;
    if (ipipRes) {
      try {
        const body = await ipipRes.json();
        if (body?.data) {
          baseInfo.pubIp = body.data.ip || "—";
          pubIpForASN = baseInfo.pubIp;
          const locArr = Array.isArray(body.data.location)
            ? body.data.location
            : (body.data.location || "").split(" ").filter(Boolean);
          // 先用 ipip 信息识别 ISP（ASN 查询结果稍后覆盖）
          baseInfo.pubIsp = getISPByIPIP(locArr[4] || locArr[3] || "", locArr) || DEFAULT_ISP;
          baseInfo.pubLoc = `${getFlagFromIPIP(locArr)} ${locArr[1] || ""} ${locArr[2] || ""}`.trim() || "—";
          // 保存 locArr 供 ASN 回来后重新判断
          baseInfo._locArr = locArr;
        }
      } catch {}
    }

    // 解析 ipinfo
    if (ipinfoRes) {
      try {
        const dt = await ipinfoRes.json();
        baseInfo.nIp = dt.ip || "—";
        baseInfo.ipinfoCountry = (dt.country || "").toUpperCase();
        const nFlag = codeToFlag(baseInfo.ipinfoCountry);
        baseInfo.nLoc = `${nFlag} ${dt.region || ""} ${dt.city || ""}`.trim() || "—";
        baseInfo.asnInfo = dt.org || "—";
        baseInfo.countryCode = baseInfo.ipinfoCountry || "XX";
      } catch {}
    }

    // ASN 查询（独立，不阻塞上面的解析）
    if (pubIpForASN) {
      try {
        const asnRes = await ctx.http.get(`https://ipapi.co/${pubIpForASN}/asn/`, { timeout: 3000 });
        baseInfo.pubASN = (await asnRes.text()).trim();
        // 用 ASN 重新判断 ISP（优先级更高）
        const ispByASN = getISPByASN(baseInfo.pubASN);
        if (ispByASN) baseInfo.pubIsp = ispByASN;
      } catch {}
    }

    return baseInfo;
  }

  // ===================== Netflix 检测（优化：og:video + reactContext） =====================
  const NETFLIX_TITLES = [
    "https://www.netflix.com/title/81280792",
    "https://www.netflix.com/title/70143836"
  ];

  async function checkNetflix(geoHint) {
    try {
      const fetchTitle = async (url) => {
        try {
          const r = await httpGetRetry(url, {
            timeout: 8000, headers: { "User-Agent": BASE_UA }, followRedirect: true
          }, 1);
          const body = await readBody(r);
          return { body: body || "", status: r?.status || 0 };
        } catch { return { body: "", status: 0 }; }
      };

      const [t1, t2] = await Promise.all([fetchTitle(NETFLIX_TITLES[0]), fetchTitle(NETFLIX_TITLES[1])]);

      if (!t1.body && !t2.body) return "❌";

      // 提取地区码（参考 Bash 脚本的 reactContext 方式）
      let region = geoHint || "XX";
      for (const body of [t1.body, t2.body]) {
        if (!body) continue;
        // 方式1: reactContext -> requestCountry.id
        const mCtx = body.match(/"requestCountry"\s*:\s*\{[^}]*"id"\s*:\s*"([A-Z]{2})"/);
        if (mCtx?.[1]) { region = mCtx[1]; break; }
        // 方式2: countryCode 字段
        const mCC = body.match(/"countryCode"\s*:\s*"?([A-Z]{2})"?/);
        if (mCC?.[1]) { region = mCC[1]; break; }
      }
      region = region.toUpperCase();

      // 检查 og:video（有 = 全解锁，无 = 仅自制剧）
      const hasFullLib1 = t1.body && t1.body.includes('og:video');
      const hasFullLib2 = t2.body && t2.body.includes('og:video');

      // 检查 "Oh no!"（受限标识）
      const oh1 = t1.body && /oh no!/i.test(t1.body);
      const oh2 = t2.body && /oh no!/i.test(t2.body);

      // 两条都 Oh no! → 受限
      if (oh1 && oh2) return "🍿";

      // 有 og:video → 全解锁
      if (hasFullLib1 || hasFullLib2) return region || "XX";

      // 无 og:video 但未 Oh no! → 仅自制剧（用 🍿 + 地区标记）
      if (region && region !== "XX") return `🍿${region}`;

      return "❌";
    } catch { return "❌"; }
  }

  // ===================== TikTok 检测（增加 store_region API） =====================
  async function checkTikTok() {
    try {
      // 优先：store_region API（更稳定）
      const storeRes = await ctx.http.post("https://www.tiktok.com/passport/web/store_region/", {
        timeout: 6000,
        headers: { "User-Agent": BASE_UA },
      }).catch(() => null);
      if (storeRes) {
        const storeBody = await readBody(storeRes);
        try {
          const storeJson = JSON.parse(storeBody);
          const sr = storeJson?.data?.store_region;
          if (sr) return sr.toUpperCase();
        } catch {}
      }

      // 回退：HTML 解析
      const fetchOnce = async (url, extra = {}) => {
        const r = await ctx.http.get(url, {
          timeout: 6000, headers: { "User-Agent": BASE_UA, ...extra }, followRedirect: true
        }).catch(() => null);
        return await readBody(r);
      };

      let body1 = await fetchOnce("https://www.tiktok.com/");
      if (body1.includes("Please wait...")) {
        body1 = await fetchOnce("https://www.tiktok.com/explore") || body1;
      }

      const m1 = body1.match(/"region"\s*:\s*"([A-Z]{2})"/);
      if (m1?.[1]) return m1[1];

      // 第二次带更完整 header
      let body2 = await fetchOnce("https://www.tiktok.com/", {
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
        "Accept-Encoding": "gzip",
        "Accept-Language": "en"
      });
      if (body2.includes("Please wait...")) {
        body2 = await fetchOnce("https://www.tiktok.com/explore", {
          "Accept-Language": "en"
        }) || body2;
      }

      const m2 = body2.match(/"region"\s*:\s*"([A-Z]{2})"/);
      if (m2?.[1]) return m2[1];

      if (body1 || body2) return "OK";
      return "❌";
    } catch { return "❌"; }
  }

  // ===================== Gemini 检测（修正正则，移除过松 fallback） =====================
  async function checkGemini() {
    try {
      const url = 'https://gemini.google.com/_/BardChatUi/data/batchexecute';
      const bodyRaw = 'f.req=[["K4WWud","[[0],[\"en-US\"]]",null,"generic"]]';
      const res = await httpPostRetry(url, {
        timeout: 10000,
        headers: { "User-Agent": BASE_UA, "Accept-Language": "en-US", "Content-Type": "application/x-www-form-urlencoded" },
        body: bodyRaw,
        followRedirect: true
      }, 1).catch(() => null);

      const txt = await readBody(res);
      if (!txt) return "❌";

      // 策略1: JSON countryCode
      let m = txt.match(/"countryCode"\s*:\s*"([A-Z]{2})"/i);
      if (m?.[1] && KNOWN_COUNTRY_CODES.has(m[1].toUpperCase())) return m[1].toUpperCase();

      // 策略2: requestCountry.id
      m = txt.match(/"requestCountry"\s*:\s*\{[^}]*"id"\s*:\s*"([A-Z]{2})"/i);
      if (m?.[1] && KNOWN_COUNTRY_CODES.has(m[1].toUpperCase())) return m[1].toUpperCase();

      // 策略3: batchexecute 编码块中的 [["XX","S 模式（参考 Bash 脚本 jq .[0][2]）
      m = txt.match(/\[\[\\?"([A-Z]{2})\\?",\\?"S/);
      if (m?.[1] && KNOWN_COUNTRY_CODES.has(m[1].toUpperCase())) return m[1].toUpperCase();

      // 能拿到响应但无法解析 → 标记为可访问但未知地区
      return "OK";
    } catch { return "❌"; }
  }

  // ===================== ChatGPT 检测（增加 WEB 中间状态 & cf_details 细分） =====================
  async function checkChatGPT() {
    try {
      // 1) chatgpt.com HEAD → 看是否有 Location（Web 是否可访问）
      const headRes = await ctx.http.get("https://chatgpt.com", {
        timeout: 10000, headers: { "User-Agent": BASE_UA }, followRedirect: false
      }).catch(() => null);
      const locationHeader = headRes?.headers?.location || headRes?.headers?.Location || "";
      const webAccessible = !!headRes && !!locationHeader;

      // 2) ios.chat.openai.com → APP 接口
      const iosRes = await ctx.http.get("https://ios.chat.openai.com", {
        timeout: 10000, headers: { "User-Agent": BASE_UA }, followRedirect: true
      }).catch(() => null);
      const iosBody = await readBody(iosRes);

      // 解析 cf_details
      let cfDetails = "";
      try {
        const j = iosBody ? JSON.parse(iosBody) : null;
        if (j?.cf_details) cfDetails = String(j.cf_details);
      } catch {
        const mc = iosBody ? iosBody.match(/"cf_details"\s*:\s*"([^"]*)"/) : null;
        if (mc?.[1]) cfDetails = mc[1];
      }

      // APP 是否被屏蔽
      const appBlocked = !iosBody
        || iosBody.includes("blocked_why_headline")
        || iosBody.includes("unsupported_country_region_territory")
        || cfDetails.includes("(1)")
        || cfDetails.includes("(2)");
      const appAccessible = !!iosBody && !appBlocked;

      // 3) 决策
      if (!webAccessible && !appAccessible) return "❌";

      // 仅 APP 可用
      if (appAccessible && !webAccessible) return "APP";

      // Web 可用但 APP 受限 → WEB（参考 Bash 脚本的 "Web Only" 状态）
      if (webAccessible && !appAccessible) {
        return "WEB";
      }

      // 两者都可用 → 获取地区码
      if (webAccessible && appAccessible) {
        const traceRes = await ctx.http.get("https://chatgpt.com/cdn-cgi/trace", {
          timeout: 8000, headers: { "User-Agent": BASE_UA }, followRedirect: true
        }).catch(() => null);
        const traceTxt = await readBody(traceRes);
        if (traceTxt) {
          const m = traceTxt.match(/loc=([A-Z]{2})/);
          if (m?.[1]) return m[1];
        }
        return "OK";
      }

      return "❌";
    } catch { return "❌"; }
  }

  // ===================== Disney+ 检测（完整版，修复冗余请求） =====================
  const DISNEY_BEARER = "Bearer ZGlzbmV5JmJyb3dzZXImMS4wLjA.Cu56AgSfBTDag5NiRA81oLHkDZfu5L3CKadnefEAY84";
  const DISNEY_DEVICES_URL = "https://disney.api.edge.bamgrid.com/devices";
  const DISNEY_TOKEN_URL = "https://disney.api.edge.bamgrid.com/token";
  const DISNEY_GQL_URL = "https://disney.api.edge.bamgrid.com/graph/v1/device/graphql";
  const DISNEY_COOKIES_PRIMARY = "https://github.com/xykt/IPQuality/raw/main/ref/cookies.txt";
  const DISNEY_COOKIES_FALLBACK = "https://testingcf.jsdelivr.net/gh/xykt/IPQuality@main/ref/cookies.txt";

  async function fetchDisneyCookieTemplates() {
    const fetchText = async (u) => {
      try {
        const r = await ctx.http.get(u, { timeout: 6000, headers: { "User-Agent": BASE_UA }, followRedirect: true });
        return ((await readBody(r)) || "").trim();
      } catch { return ""; }
    };
    const txt = (await fetchText(DISNEY_COOKIES_PRIMARY)) || (await fetchText(DISNEY_COOKIES_FALLBACK));
    if (!txt) return null;
    const lines = txt.split(/\r?\n/);
    const tokenTpl = (lines[0] || "").trim();
    const gqlTpl = (lines[7] || "").trim();
    return (tokenTpl && gqlTpl) ? { tokenTpl, gqlTpl } : null;
  }

  async function checkDisneyPlus() {
    try {
      const templates = await fetchDisneyCookieTemplates();
      if (!templates) return "❌";

      // 1) /devices → assertion
      const preRes = await ctx.http.post(DISNEY_DEVICES_URL, {
        timeout: 10000,
        headers: {
          "authorization": DISNEY_BEARER,
          "content-type": "application/json; charset=UTF-8",
          "user-agent": BASE_UA
        },
        body: JSON.stringify({ deviceFamily: "browser", applicationRuntime: "chrome", deviceProfile: "windows", attributes: {} }),
        followRedirect: true
      }).catch(() => null);

      let preJson = null;
      try { preJson = preRes ? await preRes.json() : null; } catch {}
      const assertion = preJson?.assertion;
      if (!assertion) return "❌";

      // 2) /token → refresh_token
      const tokenBody = templates.tokenTpl.replace(/DISNEYASSERTION/g, assertion);
      const tokRes = await ctx.http.post(DISNEY_TOKEN_URL, {
        timeout: 10000,
        headers: {
          "authorization": DISNEY_BEARER,
          "content-type": "application/x-www-form-urlencoded",
          "user-agent": BASE_UA
        },
        body: tokenBody,
        followRedirect: true
      }).catch(() => null);

      const tokText = await readBody(tokRes);
      if (tokText.includes("forbidden-location") || tokText.includes("403 ERROR")) return "❌";

      let tokJson = null;
      try { tokJson = tokText ? JSON.parse(tokText) : null; } catch {}
      const refreshToken = tokJson?.refresh_token;
      if (!refreshToken) return "❌";

      // 3) GraphQL
      const gqlBody = templates.gqlTpl.replace(/ILOVEDISNEY/g, refreshToken);
      const gqlRes = await ctx.http.post(DISNEY_GQL_URL, {
        timeout: 10000,
        headers: {
          "authorization": DISNEY_BEARER,
          "content-type": "application/json; charset=UTF-8",
          "user-agent": BASE_UA
        },
        body: gqlBody,
        followRedirect: true
      }).catch(() => null);

      let gqlJson = null;
      try { gqlJson = gqlRes ? await gqlRes.json() : null; } catch {}
      if (!gqlJson) return "❌";

      const region = (gqlJson?.extensions?.sdk?.session?.location?.countryCode || "").toUpperCase();
      const inSupportedLocation = gqlJson?.extensions?.sdk?.session?.inSupportedLocation;

      // 4) preview/unavailable 检测
      const webRes = await ctx.http.get("https://disneyplus.com", {
        timeout: 10000, headers: commonHeaders, followRedirect: true
      }).catch(() => null);
      const finalUrl = webRes?.url || "";
      const isUnavailable = finalUrl.includes("preview") && finalUrl.includes("unavailable");

      // 5) 分支映射
      if (region === "JP") return "JP";
      if (region && inSupportedLocation === false && !isUnavailable) return "⏳";
      if (region && isUnavailable) return "❌";
      if (region && inSupportedLocation === true) return region;
      return "❌";
    } catch { return "❌"; }
  }

  // ===================== 统一解锁检测调度 =====================
  async function checkPlatform(name, geoHint) {
    try {
      switch (name) {
        case "GPT":     return { name, region: await checkChatGPT() };
        case "Gemini":  return { name, region: await checkGemini() };
        case "奈飞":    return { name, region: await checkNetflix(geoHint) };
        case "TikTok":  return { name, region: await checkTikTok() };
        case "Disney":  return { name, region: await checkDisneyPlus() };
        default:        return { name, region: "❌" };
      }
    } catch { return { name, region: "❌" }; }
  }

  // ===================== 主逻辑 =====================
  // 网络信息
  const d = ctx.device || {};
  const isWifi = !!d.wifi?.ssid;
  let netName = "未连接", netIcon = "antenna.radiowaves.left.and.right";
  if (isWifi) {
    netName = d.wifi.ssid || "Wi‑Fi";
    netIcon = "wifi";
  } else if (d.cellular?.radio) {
    const r = d.cellular.radio.toUpperCase().replace(/\s+/g, "");
    const map = { "GPRS": "2G", "EDGE": "2G", "WCDMA": "3G", "LTE": "4G", "NR": "5G", "NRNSA": "5G" };
    netName = `蜂窝: ${map[r] || r || "5G"}`;
  }

  // ★ 最大化并行：基础信息 + 物理出口同时获取
  const [baseInfo, realPhysicalRegion] = await Promise.all([
    fetchBaseInfo(),
    getPhysicalLoc()
  ]);

  // 确定 geoHint
  const geoHint = baseInfo.ipinfoCountry || realPhysicalRegion || "XX";

  // ★ 解锁检测（全部并行）
  const unlockResults = await Promise.all([
    checkPlatform("GPT", geoHint),
    checkPlatform("Gemini", geoHint),
    checkPlatform("奈飞", geoHint),
    checkPlatform("TikTok", geoHint),
    checkPlatform("Disney", geoHint)
  ]);

  // 格式化解锁文本
  const unlockText = unlockResults.map(r => `${r.name} ${r.region}`).join("，");

  // 风险评分
  const risk = baseInfo.ipData.fraudScore;
  let riskTxt = "检测失败", riskColor = C_SUB;
  if (typeof risk === "number") {
    if (risk < 30) { riskTxt = `极高纯净 (${risk})`; riskColor = C_GREEN; }
    else if (risk < 60) { riskTxt = `中等风险 (${risk})`; riskColor = C_YELLOW; }
    else { riskTxt = `高风险警告 (${risk})`; riskColor = C_RED; }
  }

  // IP 类型
  const ipType = baseInfo.ipData.isResidential === true ? "🏠 住宅"
    : baseInfo.ipData.isResidential === false ? "🏢 机房"
    : getIPType(baseInfo.pubIsp, baseInfo.asnInfo);

  // 延迟颜色 & 文本
  const primaryDelay = baseInfo.realTcpDelay > 0 ? baseInfo.realTcpDelay : baseInfo.apiResponseTime;
  let delayColor = C_SUB;
  if (primaryDelay > 0) {
    if (primaryDelay < 150) delayColor = C_GREEN;
    else if (primaryDelay <= 350) delayColor = C_YELLOW;
    else delayColor = C_RED;
  }
  const delayText = baseInfo.realTcpDelay > 0
    ? `${baseInfo.realTcpDelay}ms (RTT) / ${baseInfo.apiResponseTime || "—"}ms (接口)`
    : `${baseInfo.apiResponseTime || "—"}ms (接口)`;

  // ===================== UI 构建 =====================
  const Row = (ic, icCol, label, val, valCol) => ({
    type: "stack", direction: "row", alignItems: "center", padding: [3, 0],
    children: [
      { type: "image", src: `sf-symbol:${ic}`, color: getThemeColor(icCol), width: 12, height: 12 },
      { type: "spacer", length: 5 },
      { type: "text", text: label, font: { size: 10 }, textColor: getThemeColor(C_SUB) },
      { type: "spacer" },
      { type: "text", text: val, font: { size: 10, weight: "medium" }, textColor: getThemeColor(valCol), maxLines: 1 }
    ]
  });

  return {
    type: "widget",
    padding: [8, 10],
    backgroundColor: getThemeColor(BG_CARD),
    cornerRadius: 12,
    refreshPolicy: { onNetworkChange: true, onEnter: true, timeout: 10 },
    children: [
      {
        type: "stack", direction: "row", alignItems: "center", padding: [2, 0, 4, 0],
        children: [
          { type: "image", src: `sf-symbol:${netIcon}`, color: getThemeColor(C_BLUE), width: 14, height: 14 },
          { type: "spacer", length: 5 },
          { type: "text", text: netName, font: { size: 13, weight: "semibold" }, textColor: getThemeColor(C_TEXT) },
          { type: "spacer" },
          { type: "text", text: delayText, font: { size: 10, weight: "medium" }, textColor: getThemeColor(delayColor) }
        ]
      },
      Row("globe", C_BLUE, "直连IP", `${baseInfo.pubIp} (${baseInfo.pubIsp})`, C_TEXT),
      Row("mappin", C_SUB, "位置", baseInfo.pubLoc, C_TEXT),
      Row("paperplane.fill", C_BLUE, "落地IP", `${baseInfo.nIp} ${ipType}`, C_TEXT),
      Row("mappin", C_SUB, "落地地区", baseInfo.nLoc, C_TEXT),
      Row("number.square.fill", C_SUB, "ASN", baseInfo.asnInfo, C_TEXT),
      Row("shield.fill", riskColor, "风险评分", riskTxt, riskColor),
      Row("play.tv.fill", C_BLUE, "解锁", unlockText, C_TEXT)
    ]
  };
}
