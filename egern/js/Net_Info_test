        });
        body2 = rExplore2.body || body2;
      }

      const m2 = body2.match(/"region"\s*:\s*"([A-Z]{2})"/);
      if (m2?.[1]) return m2[1];

      // 有内容但解析不到 region：按 OK（避免误报）
      if (body1 || body2) return "OK";

      return "❌";
    } catch {
      return "❌";
    }
  }

