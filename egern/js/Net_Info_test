/**
 * 🚀 深度流媒体解锁体检 Pro (奈飞 & TikTok 专项修复版)
 */
export default async function(ctx) {
  const BG_CARD = { light: '#FFFFFF', dark: '#1C1E1E' };
  const C_TEXT  = { light: '#000000', dark: '#FFFFFF' };
  const C_SUB   = { light: '#6E6E73', dark: '#8E8E93' };
  const C_BLUE  = { light: '#007AFF', dark: '#0A84FF' };
  const C_GREEN = { light: '#34C759', dark: '#30D158' };
  const C_RED   = { light: '#FF3B30', dark: '#FF453A' };

  const BASE_UA = "Mozilla/5.0 (iPhone; CPU iPhone OS 17_4 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.4 Mobile/15E148 Safari/604.1";

  // —————————————————— 🔥 深度区域探测引擎 ——————————————————
  const checkPlatform = async (name, url) => {
    try {
      const commonHeaders = {
        "User-Agent": BASE_UA,
        "Accept-Language": "ja-JP,ja;q=0.9,en-US;q=0.8,zh-HK;q=0.7", // 增加香港权重
        "Cache-Control": "no-cache"
      };

      // 1. 奈飞专项修复：强制刷新缓存，双重验证
      if (name === "奈飞") {
        const nfRes = await ctx.http.get("https://www.netflix.com/title/80018499", { 
          timeout: 5000, 
          headers: commonHeaders, 
          followRedirect: false 
        });
        
        let reg = nfRes.headers["x-netflix-originating-env"] || nfRes.headers["X-Netflix-Originating-Env"];
        
        // 如果第一步没拿到地区码，但状态是 200，说明全解，尝试从 HTML 内容反查
        if (nfRes.status === 200) {
           return { name, region: reg ? reg.toUpperCase() : "原生" };
        }
        
        // 判定是否为半解 (自制剧)
        const nfRes2 = await ctx.http.get("https://www.netflix.com/title/81215567", { timeout: 3500 });
        return { name, region: nfRes2.status === 200 ? "🍿" : "❌" };
      }

      // 2. TikTok 专项修复：多重正则匹配地区
      if (name === "TikTok") {
        const tkRes = await ctx.http.get("https://www.tiktok.com/", { 
          timeout: 5000, 
          headers: commonHeaders, 
          followRedirect: true 
        });
        const tkUrl = tkRes.url || "";
        // 正则 1: 路径匹配 (如 /v/HK)； 正则 2: 参数匹配 (如 ?region=HK)； 正则 3: 国际语言代码 (如 /zh-Hant-TW/)
        const regMatch = tkUrl.match(/\/v\/([A-Z]{2})/) || 
                         tkUrl.match(/region=([A-Z]{2})/) || 
                         tkUrl.match(/-([A-Z]{2})\//);
                         
        if (regMatch) return { name, region: regMatch[1].toUpperCase() };
        return { name, region: tkRes.status === 200 ? "OK" : "❌" };
      }

      // 3. Disney+
      if (name === "Disney") {
        const dsRes = await ctx.http.get("https://www.disneyplus.com/welcome/", { timeout: 5000, headers: commonHeaders, followRedirect: true });
        return { name, region: (dsRes.url.includes("preview") || dsRes.url.includes("unsupported")) ? "❌" : realPhysicalRegion };
      }

      // 4. 其他 (GPT/Gemini)
      const res = await ctx.http.get(url, { timeout: 4500, headers: commonHeaders, followRedirect: true });
      return { name, region: (!res.url.includes("error") && !res.url.includes("unsupported")) ? realPhysicalRegion : "❌" };

    } catch (e) { return { name, region: "❌" }; }
  };

  // —————————————————— 基础数据 ——————————————————
  let pubIp = "—", nIp = "—", nLoc = "—", realPhysicalRegion = "XX";

  const fetchBaseInfo = async () => {
    try {
      const [ipinfoRes, physicalRes] = await Promise.all([
        ctx.http.get('https://ipinfo.io/json', { timeout: 4000 }).catch(() => null),
        ctx.http.get('http://ip-api.com/json/?fields=countryCode', { timeout: 3000 }).catch(() => null)
      ]);

      if (physicalRes) {
        const pData = await physicalRes.json();
        realPhysicalRegion = (pData.countryCode || "XX").toUpperCase();
      }
      if (ipinfoRes) {
        const dt = await ipinfoRes.json();
        nIp = dt.ip;
        const flag = dt.country ? String.fromCodePoint(...dt.country.toUpperCase().split('').map(c => 127397 + c.charCodeAt())) : "🌐";
        nLoc = `${flag} ${dt.region || ""} ${dt.city || ""}`;
      }
    } catch(e) {}
  };

  const start = Date.now();
  await fetchBaseInfo();

  const [ipRes, results] = await Promise.all([
    ctx.http.get('https://my.ippure.com/v1/info', { timeout: 4000 }).catch(() => null),
    Promise.all([
      checkPlatform("GPT", "https://chatgpt.com/auth/login"),
      checkPlatform("奈飞", ""),
      checkPlatform("TikTok", ""),
      checkPlatform("Gemini", "https://gemini.google.com/app"),
      checkPlatform("Disney", "")
    ])
  ]);

  const unlockText = results.map(r => `${r.name} ${r.region}`).join("，");
  let ipData = {}; try { if (ipRes) ipData = await ipRes.json(); } catch(e) {}

  const Row = (ic, icCol, label, val, valCol) => ({
    type: 'stack', direction: 'row', alignItems: 'center', padding: [3, 0],
    children: [
      { type: 'image', src: `sf-symbol:${ic}`, color: icCol, width: 12, height: 12 },
      { type: 'spacer', length: 5 },
      { type: 'text', text: label, font: { size: 10 }, textColor: C_SUB },
      { type: 'spacer' },
      { type: 'text', text: val, font: { size: 10, weight: 'medium' }, textColor: valCol, maxLines: 1 }
    ]
  });

  return {
    type: 'widget', padding: [8, 10], backgroundColor: BG_CARD, cornerRadius: 12,
    children: [
      { type: 'stack', direction: 'row', alignItems: 'center', padding: [2,0,4,0], children: [
          { type: 'image', src: `sf-symbol:shield.lefthalf.filled`, color: C_BLUE, width:14, height:14 },
          { type: 'spacer', length:5 },
          { type: 'text', text: "流媒体解锁探测", font: { size:13, weight:'semibold' }, textColor: C_TEXT },
          { type: 'spacer' },
          { type: 'text', text: `${Date.now() - start}ms`, font: { size:11 }, textColor: C_GREEN }
      ]},
      Row("paperplane.fill", C_BLUE, "落地 IP", `${nIp} ${ipData.isResidential ? "🏠" : "🏢"}`, C_TEXT),
      Row("mappin", C_SUB, "物理位置", nLoc, C_TEXT),
      Row("play.tv.fill", C_BLUE, "实际解锁", unlockText, C_TEXT),
      Row("exclamationmark.shield", C_RED, "风险得分", `${ipData.fraudScore || 0}`, ipData.fraudScore >= 40 ? C_RED : C_GREEN),
    ]
  };
}
