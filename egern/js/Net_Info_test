    "https://www.netflix.com/title/70143836"  // 自制剧
  ];

  const uniq = (arr) => Array.from(new Set((arr || []).filter(Boolean)));

  const readBody = async (r) => {
    if (!r) return "";
    if (typeof r.body === "string" && r.body.length) return r.body;
    if (typeof r.text === "function") {
      try {
        const t = await r.text();
        return typeof t === "string" ? t : "";
      } catch {
        return "";
      }
    }
    return "";
  };

  async function dohResolveA(ctx, hostname, provider) {
    // 使用 DNS-over-HTTPS 获取 A 记录，尽量贴近 reference1 的多路 DNS 思路
    // provider: cloudflare | google | quad9
    const endpoints = {
      cloudflare: `https://cloudflare-dns.com/dns-query?name=${encodeURIComponent(hostname)}&type=A`,
      google: `https://dns.google/resolve?name=${encodeURIComponent(hostname)}&type=A`,
      quad9: `https://dns.quad9.net/dns-query?name=${encodeURIComponent(hostname)}&type=A`
    };
    const url = endpoints[provider];
    if (!url) return [];

    try {
      const res = await ctx.http.get(url, {
        timeout: 2500,
        headers: {
          "Accept": "application/dns-json",
          "User-Agent": BASE_UA
        },
        followRedirect: true
      });
      const data = typeof res?.json === "function" ? await res.json() : null;
      const answers = data?.Answer || data?.answer || [];
      const ips = (answers || [])
        .filter(a => a && (a.type === 1 || a.type === "A") && typeof a.data === "string")
        .map(a => a.data);
      return uniq(ips);
    } catch {
      return [];
    }
  }

  function getUnlockTypeFromDns(ips1, ips2, ips3) {
    // 这是 JS 版的“Get_Unlock_Type”简化实现：
    // - 三路 DNS 返回一致：大概率原生
    // - 存在明显差异：可能 DNS 解锁/污染/分流
    const a = uniq(ips1).sort().join(",");
    const b = uniq(ips2).sort().join(",");
    const c = uniq(ips3).sort().join(",");
    if (!a && !b && !c) return "DNS未知";
    if (a && a === b && a === c) return "原生DNS";
    // 只要有两路一致也算“较稳定”，否则认为差异明显
    const sameAB = a && b && a === b;
    const sameAC = a && c && a === c;
    const sameBC = b && c && b === c;
    if (sameAB || sameAC || sameBC) return "疑似分流";
    return "疑似DNS解锁";
  }

  function extractNetflixRegion(body1, body2, geoHint = "XX") {
    const bodies = [body1, body2].filter(Boolean);
    for (const b of bodies) {
      // 尽量兼容不同页面结构：countryCode / id + countryName
      const m1 = b.match(/"countryCode"\s*:\s*"?([A-Z]{2})"?/);
      if (m1?.[1]) return m1[1];
      const m2 = b.match(/"id"\s*:\s*"?([A-Z]{2})"?.{0,200}?"countryName"\s*:\s*"/);
      if (m2?.[1]) return m2[1];
    }
    return (geoHint || "XX").toUpperCase();
  }

  // ===================== Netflix 检测函数（实现 Bash MediaUnlockTest_Netflix 逻辑）=====================
  async function checkNetflix(ctx, geoHint = "XX") {
    try {
      // 1) 多路 DNS 查询（用于诊断，UI 目前只显示国家码/🍿/❌）
      const host = "netflix.com";
      await Promise.all([
        dohResolveA(ctx, host, 'cloudflare'),
        dohResolveA(ctx, host, 'google'),
        dohResolveA(ctx, host, 'quad9')
      ]).catch(() => []);

      // 2) 并发拉取两条用于判定的 title 页面
      const fetchTitle = async (url) => {
        const r = await ctx.http.get(url, {
          timeout: 10000,
          headers: { "User-Agent": BASE_UA },
          followRedirect: true
        }).catch(() => null);
        const body = await readBody(r);
        return { body: body || "", status: r?.status || 0, url: r?.url || url };
      };

      const [t1, t2] = await Promise.all([fetchTitle(NETFLIX_TITLES[0]), fetchTitle(NETFLIX_TITLES[1])]);

      // 3) 若两条均为空，认为无数据/无法访问 -> ❌
      if (!t1.body && !t2.body) return "❌";

      // 4) 提取地区（优先从页面内容解析，兜底使用 geoHint）
      const region = (extractNetflixRegion(t1.body || "", t2.body || "", geoHint) || "XX").toUpperCase();

      // 5) 检测是否包含 "Oh no!"（受限标识）
      const oh1 = t1.body && /oh no!/i.test(t1.body);
      const oh2 = t2.body && /oh no!/i.test(t2.body);

      // 两条都出现 Oh no! -> 受限 -> 返回 🍿
      if (oh1 && oh2) return "🍿";

      // 至少一条未出现 Oh no! -> 可用 -> 返回地区码（如 DE）
      if (!oh1 || !oh2) return region || "XX";

      // 兜底
      return "❌";
    } catch (e) {
      return "❌";
    }
  }

  // ===================== TikTok 检测（按 reference1 思路：region + Please wait... 兜底）=====================
  async function checkTikTok(ctx) {
    try {
      // reference1: 先拉主页，若遇到 "Please wait..." 再拉 /explore
      const fetchOnce = async (url, extraHeaders = {}) => {
        const r = await ctx.http.get(url, {
          timeout: 6000,
          headers: { "User-Agent": BASE_UA, ...extraHeaders },
          followRedirect: true
        }).catch(() => null);
        const body = await readBody(r);
        return { status: r?.status || 0, body };
      };

      const r1 = await fetchOnce("https://www.tiktok.com/");
      let body1 = r1.body || "";
      if (body1.includes("Please wait...")) {
        const rExplore = await fetchOnce("https://www.tiktok.com/explore");
        body1 = rExplore.body || body1;
      }

      // reference1: 从 HTML 中 grep '"region":' 抽取
      const m1 = body1.match(/"region"\s*:\s*"([A-Z]{2})"/);
      if (m1?.[1]) return m1[1];

      // reference1: 第二次带更完整 header（含 gzip / en）
      const r2 = await fetchOnce("https://www.tiktok.com/", {
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8,application/signed-exchange;v=b3;q=0.9",
        "Accept-Encoding": "gzip",
        "Accept-Language": "en"
      });
      let body2 = r2.body || "";
      if (body1.includes("Please wait...")) {
        const rExplore2 = await fetchOnce("https://www.tiktok.com/explore", {
          "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8,application/signed-exchange;v=b3;q=0.9",
          "Accept-Encoding": "gzip",
